@model cinemaBooking.Models.ViewModels.MovieFormViewModel

<div class="row g-3">
    <div class="col-md-8">
        <label asp-for="TenPhim" class="form-label">Tên phim *</label>
        <input asp-for="TenPhim" class="form-control" />
        <span asp-validation-for="TenPhim" class="text-danger small"></span>
    </div>
    <div class="col-md-4">
        <label asp-for="TenGoc" class="form-label">Tên gốc</label>
        <input asp-for="TenGoc" class="form-control" />
    </div>
    <div class="col-12">
        <label asp-for="MoTa" class="form-label">Mô tả</label>
        <textarea asp-for="MoTa" class="form-control" rows="3"></textarea>
    </div>
    <div class="col-md-3">
        <label asp-for="ThoiLuong" class="form-label">Thời lượng (phút) *</label>
        <input asp-for="ThoiLuong" class="form-control" type="number" />
        <span asp-validation-for="ThoiLuong" class="text-danger small"></span>
    </div>
    <div class="col-md-3">
        <label asp-for="NgayChieu" class="form-label">Ngày khởi chiếu</label>
        <input asp-for="NgayChieu" class="form-control" type="date" />
    </div>
    <div class="col-md-3">
        <label asp-for="NgayKetThuc" class="form-label">Ngày kết thúc</label>
        <input asp-for="NgayKetThuc" class="form-control" type="date" />
    </div>
    <div class="col-md-3">
        <label asp-for="DiemDanhGia" class="form-label">Điểm đánh giá (0-10)</label>
        <input asp-for="DiemDanhGia" class="form-control" type="number" step="0.1" />
    </div>
    <div class="col-md-3">
        <label asp-for="NgonNgu" class="form-label">Ngôn ngữ</label>
        <input asp-for="NgonNgu" class="form-control" placeholder="Tiếng Việt" />
    </div>
    <div class="col-md-3">
        <label asp-for="QuocGia" class="form-label">Quốc gia</label>
        <input asp-for="QuocGia" class="form-control" placeholder="Việt Nam" />
    </div>
    <div class="col-md-3">
        <label asp-for="DoTuoiQuyDinh" class="form-label">Giới hạn độ tuổi</label>
        <select asp-for="DoTuoiQuyDinh" class="form-select">
            <option value="P">P (Mọi lứa tuổi)</option>
            <option value="C13">C13 (Trên 13 tuổi)</option>
            <option value="C16">C16 (Trên 16 tuổi)</option>
            <option value="C18">C18 (Trên 18 tuổi)</option>
        </select>
    </div>
    <div class="col-md-3">
        <label asp-for="TrangThaiChieu" class="form-label">Trạng thái</label>
        <select asp-for="TrangThaiChieu" class="form-select">
            <option value="ComingSoon">Sắp chiếu</option>
            <option value="NowShowing">Đang chiếu</option>
            <option value="Ended">Đã kết thúc</option>
        </select>
    </div>
    <div class="col-md-6">
        <label asp-for="DaoDien" class="form-label">Đạo diễn</label>
        <input asp-for="DaoDien" class="form-control" />
    </div>
    <div class="col-md-6">
        <label asp-for="DienVien" class="form-label">Diễn viên (cách nhau bằng dấu phẩy)</label>
        <input asp-for="DienVien" class="form-control" />
    </div>
    <div class="col-md-6">
        <label asp-for="AnhPoster" class="form-label">URL Poster phim</label>
        <input asp-for="AnhPoster" class="form-control" placeholder="https://..." />
    </div>
    <div class="col-md-6">
        <label asp-for="LinkTrailer" class="form-label">URL Trailer (YouTube)</label>
        <input asp-for="LinkTrailer" class="form-control" placeholder="https://youtube.com/..." />
    </div>
    <div class="col-12">
        <label class="form-label">Thể loại</label>
        <div class="d-flex flex-wrap gap-3">
            @for (int i = 0; i < Model.TatCaTheLoai.Count; i++)
            {
                <div class="form-check">
                    <input type="checkbox" name="MaTheLoaisDaChon" value="@Model.TatCaTheLoai[i].Id"
                           id="genre_@Model.TatCaTheLoai[i].Id" class="form-check-input"
                           @(Model.TatCaTheLoai[i].IsChecked ? "checked" : "") />
                    <label for="genre_@Model.TatCaTheLoai[i].Id" class="form-check-label">@Model.TatCaTheLoai[i].TenTheLoai</label>
                </div>
            }
        </div>
    </div>
</div>
