@model cinemaBooking.Models.ViewModels.MovieFormViewModel
@{
    ViewData["Title"] = "Sửa phim";
}

<div class="container mt-4">
    <nav aria-label="breadcrumb">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a asp-controller="Admin" asp-action="Dashboard">Admin</a></li>
            <li class="breadcrumb-item"><a asp-controller="Admin" asp-action="Movies">Phim</a></li>
            <li class="breadcrumb-item active">Sửa</li>
        </ol>
    </nav>
    <h3 class="fw-bold mb-4"><i class="fas fa-edit me-2 text-danger"></i>Sửa phim: @Model.TenPhim</h3>
    <form asp-action="Edit" asp-route-id="@Model.Id" method="post">
        @Html.AntiForgeryToken()
        @await Html.PartialAsync("_MovieFormPartial", Model)
        <div class="mt-3">
            <button type="submit" class="btn btn-danger"><i class="fas fa-save me-2"></i>Lưu thay đổi</button>
            <a asp-controller="Admin" asp-action="Movies" class="btn btn-outline-secondary ms-2">Hủy</a>
        </div>
    </form>
</div>

@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
}
