<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Cinema Star</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.2/css/all.min.css" rel="stylesheet" />
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
    <nav class="navbar navbar-expand-lg navbar-dark bg-dark sticky-top">
        <div class="container">
            <a class="navbar-brand fw-bold" asp-controller="Home" asp-action="Index">
                <i class="fas fa-film me-2 text-danger"></i>Cinema Star
            </a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarMain">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="navbarMain">
                <ul class="navbar-nav me-auto">
                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Home" asp-action="Index">
                            <i class="fas fa-home me-1"></i>Trang chủ
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Movie" asp-action="Index">
                            <i class="fas fa-film me-1"></i>Phim
                        </a>
                    </li>
                    @if (User.IsInRole("Admin"))
                    {
                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle" href="#" data-bs-toggle="dropdown">
                                <i class="fas fa-cog me-1"></i>Quản trị
                            </a>
                            <ul class="dropdown-menu dropdown-menu-dark">
                                <li><a class="dropdown-item" asp-controller="Admin" asp-action="Dashboard"><i class="fas fa-tachometer-alt me-2"></i>Dashboard</a></li>
                                <li><a class="dropdown-item" asp-controller="Admin" asp-action="Movies"><i class="fas fa-film me-2"></i>Quản lý Phim</a></li>
                                <li><a class="dropdown-item" asp-controller="Admin" asp-action="Showtimes"><i class="fas fa-calendar me-2"></i>Suất chiếu</a></li>
                                <li><a class="dropdown-item" asp-controller="Admin" asp-action="Bookings"><i class="fas fa-ticket-alt me-2"></i>Đơn đặt vé</a></li>
                                <li><a class="dropdown-item" asp-controller="Admin" asp-action="Users"><i class="fas fa-users me-2"></i>Người dùng</a></li>
                                <li><a class="dropdown-item" asp-controller="Admin" asp-action="Cinemas"><i class="fas fa-building me-2"></i>Rạp chiếu</a></li>
                            </ul>
                        </li>
                    }
                </ul>
                <ul class="navbar-nav ms-auto">
                    @if (User.Identity?.IsAuthenticated == true)
                    {
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Booking" asp-action="History">
                                <i class="fas fa-ticket-alt me-1"></i>Vé của tôi
                            </a>
                        </li>
                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle" href="#" data-bs-toggle="dropdown">
                                <span class="avatar-circle me-1">@User.Identity.Name?.Substring(0, 1)?.ToUpper()</span>
                                @User.Identity.Name?.Split(' ')?.Last()
                            </a>
                            <ul class="dropdown-menu dropdown-menu-end dropdown-menu-dark">
                                <li><span class="dropdown-item-text text-muted small">@User.Identity.Name</span></li>
                                <li><hr class="dropdown-divider" /></li>
                                <li><a class="dropdown-item" asp-controller="Account" asp-action="Profile"><i class="fas fa-user me-2"></i>Hồ sơ</a></li>
                                <li><a class="dropdown-item" asp-controller="Account" asp-action="ChangePassword"><i class="fas fa-key me-2"></i>Đổi mật khẩu</a></li>
                                <li><hr class="dropdown-divider" /></li>
                                <li>
                                    <form asp-controller="Account" asp-action="Logout" method="post">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="dropdown-item text-danger">
                                            <i class="fas fa-sign-out-alt me-2"></i>Đăng xuất
                                        </button>
                                    </form>
                                </li>
                            </ul>
                        </li>
                    }
                    else
                    {
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Account" asp-action="Login">
                                <i class="fas fa-sign-in-alt me-1"></i>Đăng nhập
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="btn btn-danger btn-sm ms-2" asp-controller="Account" asp-action="Register">
                                Đăng ký
                            </a>
                        </li>
                    }
                </ul>
            </div>
        </div>
    </nav>

    <main>
        @if (TempData["Success"] != null)
        {
            <div class="container mt-3">
                <div class="alert alert-success alert-dismissible fade show">
                    <i class="fas fa-check-circle me-2"></i>@TempData["Success"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            </div>
        }
        @if (TempData["Error"] != null)
        {
            <div class="container mt-3">
                <div class="alert alert-danger alert-dismissible fade show">
                    <i class="fas fa-exclamation-circle me-2"></i>@TempData["Error"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            </div>
        }
        @RenderBody()
    </main>

    <footer class="bg-dark text-light mt-5 py-4">
        <div class="container">
            <div class="row">
                <div class="col-md-4">
                    <h6 class="fw-bold"><i class="fas fa-film me-2 text-danger"></i>Cinema Star</h6>
                    <p class="small text-muted">Trải nghiệm điện ảnh đỉnh cao – đặt vé nhanh, chọn ghế dễ.</p>
                </div>
                <div class="col-md-4">
                    <h6 class="fw-bold">Liên kết</h6>
                    <ul class="list-unstyled small">
                        <li><a class="text-muted text-decoration-none" asp-controller="Movie" asp-action="Index">Phim đang chiếu</a></li>
                        <li><a class="text-muted text-decoration-none" asp-controller="Movie" asp-action="Index" asp-route-status="ComingSoon">Phim sắp chiếu</a></li>
                        @if (User.Identity?.IsAuthenticated == true)
                        {
                            <li><a class="text-muted text-decoration-none" asp-controller="Booking" asp-action="History">Lịch sử đặt vé</a></li>
                        }
                    </ul>
                </div>
                <div class="col-md-4">
                    <h6 class="fw-bold">Liên hệ</h6>
                    <p class="small text-muted">
                        <i class="fas fa-envelope me-2"></i>hotro@cinemastar.vn<br />
                        <i class="fas fa-phone me-2"></i>1900 6789
                    </p>
                </div>
            </div>
            <hr class="border-secondary" />
            <p class="text-center text-muted small mb-0">&copy; 2025 Cinema Star. Bản quyền thuộc về Vũ Khắc Diệp.</p>
        </div>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
