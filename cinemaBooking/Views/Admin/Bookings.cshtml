@model List<cinemaBooking.Models.ViewModels.BookingHistoryItemViewModel>
@{
    ViewData["Title"] = "Quản lý đơn đặt vé";
}

<div class="container-fluid mt-4">
    <div class="row">
        <div class="col-md-2">@await Html.PartialAsync("_AdminSidebar")</div>
        <div class="col-md-10">
            <h3 class="fw-bold mb-4"><i class="fas fa-ticket-alt me-2 text-danger"></i>Đơn đặt vé</h3>

            <form asp-action="Bookings" method="get" class="row g-2 mb-3">
                <div class="col-md-3">
                    <select name="status" class="form-select">
                        <option value="">-- Tất cả --</option>
                        <option value="Pending" selected="@(ViewBag.Status == "Pending")">Đang chờ</option>
                        <option value="Confirmed" selected="@(ViewBag.Status == "Confirmed")">Đã xác nhận</option>
                        <option value="Cancelled" selected="@(ViewBag.Status == "Cancelled")">Đã hủy</option>
                    </select>
                </div>
                <div class="col-md-2">
                    <button type="submit" class="btn btn-outline-secondary w-100"><i class="fas fa-filter me-1"></i>Lọc</button>
                </div>
            </form>

            <div class="card">
                <div class="table-responsive">
                    <table class="table table-hover mb-0">
                        <thead><tr><th>Mã vé</th><th>Phim</th><th>Rạp</th><th>Suất chiếu</th><th>Ghế</th><th>Tiền</th><th>Trạng thái</th><th>Ngày</th></tr></thead>
                        <tbody>
                            @foreach (var b in Model)
                            {
                                <tr>
                                    <td><code>@b.BookingCode</code></td>
                                    <td class="text-truncate fw-bold" style="max-width:130px">@b.MovieTitle</td>
                                    <td class="small text-muted">@b.CinemaName</td>
                                    <td class="small">@b.ShowtimeStart.ToString("HH:mm dd/MM")</td>
                                    <td>@b.SeatCount ghế</td>
                                    <td class="fw-bold">@b.TotalAmount.ToString("N0")đ</td>
                                    <td>
                                        @{var (cls,txt) = b.BookingStatus switch {"Confirmed"=>("success","Xác nhận"),"Cancelled"=>("secondary","Hủy"),_=>("warning","Chờ")};}
                                        <span class="badge bg-@cls">@txt</span>
                                    </td>
                                    <td class="small text-muted">@b.CreatedAt.ToString("dd/MM HH:mm")</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>
