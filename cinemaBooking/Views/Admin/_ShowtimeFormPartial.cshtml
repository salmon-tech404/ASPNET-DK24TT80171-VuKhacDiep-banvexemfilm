@model cinemaBooking.Models.ViewModels.ShowtimeFormViewModel

<div class="row g-3">
    <div class="col-md-6">
        <label asp-for="MaPhim" class="form-label">Phim *</label>
        <select asp-for="MaPhim" class="form-select">
            <option value="">-- Chọn phim --</option>
            @foreach (var m in Model.Phims)
            {
                <option value="@m.Id" selected="@(Model.MaPhim == m.Id)">@m.TenPhim</option>
            }
        </select>
        <span asp-validation-for="MaPhim" class="text-danger small"></span>
    </div>
    <div class="col-md-6">
        <label asp-for="MaPhong" class="form-label">Phòng chiếu *</label>
        <select asp-for="MaPhong" class="form-select">
            <option value="">-- Chọn phòng --</option>
            @foreach (var r in Model.Phongs)
            {
                <option value="@r.Id" selected="@(Model.MaPhong == r.Id)">@r.TenRap – @r.TenPhong</option>
            }
        </select>
        <span asp-validation-for="MaPhong" class="text-danger small"></span>
    </div>
    <div class="col-md-4">
        <label asp-for="GioBatDau" class="form-label">Thời gian bắt đầu *</label>
        <input asp-for="GioBatDau" class="form-control" type="datetime-local" />
        <span asp-validation-for="GioBatDau" class="text-danger small"></span>
    </div>
    <div class="col-md-4">
        <label asp-for="PhongDich" class="form-label">Phụ đề / Lồng tiếng</label>
        <select asp-for="PhongDich" class="form-select">
            <option value="Vietsub">Vietsub</option>
            <option value="Dubbed">Lồng tiếng</option>
            <option value="Original">Tiếng gốc</option>
        </select>
    </div>
    <div class="col-md-4">
        <label asp-for="DinhDang" class="form-label">Định dạng</label>
        <select asp-for="DinhDang" class="form-select">
            <option value="2D">2D</option>
            <option value="3D">3D</option>
            <option value="4DX">4DX</option>
            <option value="IMAX">IMAX</option>
        </select>
    </div>
    <div class="col-md-4">
        <label asp-for="GiaVeCoBan" class="form-label">Giá vé cơ bản (VNĐ) *</label>
        <input asp-for="GiaVeCoBan" class="form-control" type="number" placeholder="85000" />
        <span asp-validation-for="GiaVeCoBan" class="text-danger small"></span>
    </div>
    <div class="col-md-4">
        <label asp-for="TrangThaiSuat" class="form-label">Trạng thái</label>
        <select asp-for="TrangThaiSuat" class="form-select">
            <option value="Scheduled">Đã lên lịch</option>
            <option value="Ongoing">Đang chiếu</option>
            <option value="Completed">Hoàn thành</option>
            <option value="Cancelled">Đã hủy</option>
        </select>
    </div>
</div>
