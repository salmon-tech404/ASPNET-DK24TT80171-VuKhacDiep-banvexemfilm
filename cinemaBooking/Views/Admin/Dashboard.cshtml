@model cinemaBooking.Models.ViewModels.AdminDashboardViewModel
@{
    ViewData["Title"] = "Dashboard Admin";
}

<div class="container-fluid mt-4">
    <div class="row">
        <!-- Sidebar -->
        <div class="col-md-2">
            @await Html.PartialAsync("_AdminSidebar")
        </div>
        <!-- Content -->
        <div class="col-md-10">
            <h3 class="fw-bold mb-4"><i class="fas fa-tachometer-alt me-2 text-danger"></i>Dashboard</h3>

            <!-- KPI Cards -->
            <div class="row g-3 mb-4">
                <div class="col-6 col-md-3">
                    <div class="card text-white bg-danger">
                        <div class="card-body d-flex justify-content-between align-items-center">
                            <div>
                                <div class="small">Tổng phim</div>
                                <div class="fs-3 fw-bold">@Model.TotalMovies</div>
                                <div class="small opacity-75">@Model.NowShowingMovies đang chiếu</div>
                            </div>
                            <i class="fas fa-film fa-2x opacity-50"></i>
                        </div>
                    </div>
                </div>
                <div class="col-6 col-md-3">
                    <div class="card text-white bg-primary">
                        <div class="card-body d-flex justify-content-between align-items-center">
                            <div>
                                <div class="small">Người dùng</div>
                                <div class="fs-3 fw-bold">@Model.TotalUsers</div>
                            </div>
                            <i class="fas fa-users fa-2x opacity-50"></i>
                        </div>
                    </div>
                </div>
                <div class="col-6 col-md-3">
                    <div class="card text-white bg-success">
                        <div class="card-body d-flex justify-content-between align-items-center">
                            <div>
                                <div class="small">Đơn đặt vé</div>
                                <div class="fs-3 fw-bold">@Model.TotalBookings</div>
                                <div class="small opacity-75">@Model.PendingBookings chờ xử lý</div>
                            </div>
                            <i class="fas fa-ticket-alt fa-2x opacity-50"></i>
                        </div>
                    </div>
                </div>
                <div class="col-6 col-md-3">
                    <div class="card text-white bg-warning">
                        <div class="card-body d-flex justify-content-between align-items-center">
                            <div>
                                <div class="small">Doanh thu</div>
                                <div class="fs-4 fw-bold">@Model.TotalRevenue.ToString("N0")đ</div>
                            </div>
                            <i class="fas fa-coins fa-2x opacity-50"></i>
                        </div>
                    </div>
                </div>
            </div>

            <div class="row g-4">
                <!-- Recent Bookings -->
                <div class="col-md-8">
                    <div class="card">
                        <div class="card-header fw-bold">
                            <i class="fas fa-ticket-alt me-2"></i>Đơn đặt vé gần đây
                        </div>
                        <div class="table-responsive">
                            <table class="table table-hover mb-0">
                                <thead><tr>
                                    <th>Mã vé</th><th>Phim</th><th>Tiền</th><th>Trạng thái</th><th>Ngày</th>
                                </tr></thead>
                                <tbody>
                                    @foreach (var b in Model.RecentBookings)
                                    {
                                        <tr>
                                            <td><code>@b.BookingCode</code></td>
                                            <td class="text-truncate" style="max-width:150px">@b.MovieTitle</td>
                                            <td>@b.TotalAmount.ToString("N0")đ</td>
                                            <td>
                                                @{var (cls,txt) = b.Status switch {"Confirmed"=>("success","Xác nhận"),"Cancelled"=>("secondary","Hủy"),_=>("warning","Chờ")};}
                                                <span class="badge bg-@cls">@txt</span>
                                            </td>
                                            <td class="small text-muted">@b.CreatedAt.ToString("dd/MM HH:mm")</td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
                <!-- Top Movies -->
                <div class="col-md-4">
                    <div class="card">
                        <div class="card-header fw-bold"><i class="fas fa-trophy me-2"></i>Phim bán chạy</div>
                        <div class="list-group list-group-flush">
                            @foreach (var (m, i) in Model.TopMovies.Select((m, i) => (m, i + 1)))
                            {
                                <div class="list-group-item d-flex justify-content-between align-items-center">
                                    <div>
                                        <span class="badge bg-danger me-2">@i</span>
                                        <span class="small fw-bold">@m.Title</span>
                                    </div>
                                    <span class="badge bg-light text-dark">@m.BookingCount vé</span>
                                </div>
                            }
                        </div>
                    </div>
                    <div class="mt-3 d-grid gap-2">
                        <a asp-action="Movies" class="btn btn-outline-danger btn-sm"><i class="fas fa-plus me-1"></i>Thêm phim</a>
                        <a asp-action="CreateShowtime" class="btn btn-outline-primary btn-sm"><i class="fas fa-calendar-plus me-1"></i>Thêm suất chiếu</a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
