@model List<cinemaBooking.Models.Domain.User>
@{
    ViewData["Title"] = "Quản lý người dùng";
}

<div class="container-fluid mt-4">
    <div class="row">
        <div class="col-md-2">@await Html.PartialAsync("_AdminSidebar")</div>
        <div class="col-md-10">
            <h3 class="fw-bold mb-4"><i class="fas fa-users me-2 text-danger"></i>Người dùng</h3>

            <form asp-action="Users" method="get" class="row g-2 mb-3">
                <div class="col-md-5">
                    <input type="text" name="search" value="@ViewBag.Search" class="form-control" placeholder="Tìm theo tên hoặc email..." />
                </div>
                <div class="col-md-3">
                    <select name="role" class="form-select">
                        <option value="">-- Tất cả vai trò --</option>
                        <option value="Admin" selected="@(ViewBag.Role == "Admin")">Admin</option>
                        <option value="Customer" selected="@(ViewBag.Role == "Customer")">Khách hàng</option>
                    </select>
                </div>
                <div class="col-md-2">
                    <button type="submit" class="btn btn-outline-secondary w-100"><i class="fas fa-search me-1"></i>Lọc</button>
                </div>
            </form>

            <div class="card">
                <div class="table-responsive">
                    <table class="table table-hover mb-0">
                        <thead><tr><th>Tên</th><th>Email</th><th>SĐT</th><th>Vai trò</th><th>Trạng thái</th><th>Ngày tạo</th><th>Thao tác</th></tr></thead>
                        <tbody>
                            @foreach (var u in Model)
                            {
                                <tr class="@(u.IsActive ? "" : "table-secondary")">
                                    <td><strong>@u.FullName</strong></td>
                                    <td class="text-muted small">@u.Email</td>
                                    <td class="small">@(u.Phone ?? "—")</td>
                                    <td>
                                        <form asp-action="ChangeUserRole" method="post" class="d-inline">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="id" value="@u.Id" />
                                            <select name="role" class="form-select form-select-sm" style="width:120px" onchange="this.form.submit()">
                                                <option value="Admin" selected="@(u.Role == "Admin")">Admin</option>
                                                <option value="Customer" selected="@(u.Role == "Customer")">Khách hàng</option>
                                            </select>
                                        </form>
                                    </td>
                                    <td>
                                        <span class="badge @(u.IsActive ? "bg-success" : "bg-secondary")">
                                            @(u.IsActive ? "Hoạt động" : "Tạm khóa")
                                        </span>
                                    </td>
                                    <td class="small text-muted">@u.CreatedAt.ToString("dd/MM/yyyy")</td>
                                    <td>
                                        <form asp-action="ToggleUserStatus" asp-route-id="@u.Id" method="post" class="d-inline">
                                            @Html.AntiForgeryToken()
                                            <button type="submit" class="btn btn-sm @(u.IsActive ? "btn-outline-warning" : "btn-outline-success")">
                                                <i class="fas @(u.IsActive ? "fa-lock" : "fa-unlock")"></i>
                                            </button>
                                        </form>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>
