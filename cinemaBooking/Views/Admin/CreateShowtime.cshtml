@model cinemaBooking.Models.ViewModels.ShowtimeFormViewModel
@{
    ViewData["Title"] = "Thêm suất chiếu";
}

<div class="container-fluid mt-4">
    <div class="row">
        <div class="col-md-2">@await Html.PartialAsync("_AdminSidebar")</div>
        <div class="col-md-10">
            <h3 class="fw-bold mb-4"><i class="fas fa-calendar-plus me-2 text-danger"></i>Thêm suất chiếu</h3>
            <div class="card">
                <div class="card-body">
                    <form asp-action="CreateShowtime" method="post">
                        @Html.AntiForgeryToken()
                        @await Html.PartialAsync("_ShowtimeFormPartial", Model)
                        <div class="mt-3">
                            <button type="submit" class="btn btn-danger"><i class="fas fa-save me-2"></i>Lưu</button>
                            <a asp-action="Showtimes" class="btn btn-outline-secondary ms-2">Hủy</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts { @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); } }
