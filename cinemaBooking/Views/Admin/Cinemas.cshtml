@model List<cinemaBooking.Models.Domain.RapChieu>
@{
    ViewData["Title"] = "Rạp chiếu phim";
}

<div class="container-fluid mt-4">
    <div class="row">
        <div class="col-md-2">@await Html.PartialAsync("_AdminSidebar")</div>
        <div class="col-md-10">
            <h3 class="fw-bold mb-4"><i class="fas fa-building me-2 text-danger"></i>Rạp chiếu phim</h3>
            <div class="row g-3">
                @foreach (var c in Model)
                {
                    <div class="col-md-4">
                        <div class="card h-100">
                            <div class="card-body">
                                <h5 class="fw-bold">@c.TenRap</h5>
                                <p class="text-muted mb-1"><i class="fas fa-map-marker-alt me-2"></i>@c.DiaChi</p>
                                <p class="text-muted mb-1"><i class="fas fa-city me-2"></i>@c.ThanhPho</p>
                                @if (!string.IsNullOrEmpty(c.DienThoai))
                                {
                                    <p class="text-muted mb-1"><i class="fas fa-phone me-2"></i>@c.DienThoai</p>
                                }
                                @if (!string.IsNullOrEmpty(c.Email))
                                {
                                    <p class="text-muted mb-1"><i class="fas fa-envelope me-2"></i>@c.Email</p>
                                }
                                <span class="badge @(c.TrangThai ? "bg-success" : "bg-secondary")">
                                    @(c.TrangThai ? "Hoạt động" : "Tạm ngưng")
                                </span>
                            </div>
                        </div>
                    </div>
                }
            </div>
        </div>
    </div>
</div>
