@model List<cinemaBooking.Models.ViewModels.ShowtimeAdminListViewModel>
@{
    ViewData["Title"] = "Quản lý suất chiếu";
}

<div class="container-fluid mt-4">
    <div class="row">
        <div class="col-md-2">@await Html.PartialAsync("_AdminSidebar")</div>
        <div class="col-md-10">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <h3 class="fw-bold mb-0"><i class="fas fa-calendar me-2 text-danger"></i>Suất chiếu</h3>
                <a asp-action="CreateShowtime" class="btn btn-danger"><i class="fas fa-plus me-1"></i>Thêm suất chiếu</a>
            </div>
            <div class="card">
                <div class="table-responsive">
                    <table class="table table-hover mb-0">
                        <thead><tr>
                            <th>Phim</th><th>Rạp / Phòng</th><th>Bắt đầu</th><th>Định dạng</th><th>Giá vé</th><th>Đặt vé</th><th>Trạng thái</th><th>Thao tác</th>
                        </tr></thead>
                        <tbody>
                            @foreach (var st in Model)
                            {
                                <tr>
                                    <td class="fw-bold text-truncate" style="max-width:150px">@st.MovieTitle</td>
                                    <td class="small">@st.CinemaName<br /><span class="text-muted">@st.RoomName</span></td>
                                    <td class="small">@st.StartTime.ToString("HH:mm")<br /><span class="text-muted">@st.StartTime.ToString("dd/MM/yyyy")</span></td>
                                    <td><span class="badge bg-dark">@st.Format</span> @st.SubType</td>
                                    <td>@st.BasePrice.ToString("N0")đ</td>
                                    <td>@st.BookingsCount vé</td>
                                    <td>
                                        @{var (cls,txt) = st.Status switch {"Scheduled"=>("success","Đã lên lịch"),"Ongoing"=>("warning","Đang chiếu"),"Completed"=>("info","Hoàn thành"),_=>("secondary","Đã hủy")};}
                                        <span class="badge bg-@cls">@txt</span>
                                    </td>
                                    <td>
                                        <a asp-action="EditShowtime" asp-route-id="@st.Id" class="btn btn-sm btn-outline-primary me-1"><i class="fas fa-edit"></i></a>
                                        <form asp-action="DeleteShowtime" asp-route-id="@st.Id" method="post" class="d-inline"
                                              onsubmit="return confirm('Hủy suất chiếu này?')">
                                            @Html.AntiForgeryToken()
                                            <button type="submit" class="btn btn-sm btn-outline-danger"><i class="fas fa-ban"></i></button>
                                        </form>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>
