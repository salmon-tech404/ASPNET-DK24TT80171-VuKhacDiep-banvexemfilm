@model cinemaBooking.Models.ViewModels.ProfileViewModel
@{
    ViewData["Title"] = "Hồ sơ của tôi";
}

<div class="container mt-4">
    <div class="row">
        <div class="col-md-4 mb-4">
            <div class="card text-center p-4">
                <div class="avatar-lg mx-auto mb-3">
                    @Model.FullName.Substring(0, 1).ToUpper()
                </div>
                <h5 class="fw-bold">@Model.FullName</h5>
                <p class="text-muted">@Model.Email</p>
                <a asp-action="ChangePassword" class="btn btn-outline-secondary btn-sm">
                    <i class="fas fa-key me-1"></i>Đổi mật khẩu
                </a>
            </div>
        </div>
        <div class="col-md-8">
            <div class="card">
                <div class="card-header fw-bold"><i class="fas fa-edit me-2"></i>Cập nhật thông tin</div>
                <div class="card-body">
                    <form asp-action="Profile" method="post">
                        @Html.AntiForgeryToken()
                        <div class="mb-3">
                            <label asp-for="FullName" class="form-label">Họ và tên</label>
                            <input asp-for="FullName" class="form-control" />
                            <span asp-validation-for="FullName" class="text-danger small"></span>
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Email</label>
                            <input value="@Model.Email" class="form-control" disabled />
                        </div>
                        <div class="mb-3">
                            <label asp-for="Phone" class="form-label">Số điện thoại</label>
                            <input asp-for="Phone" class="form-control" />
                        </div>
                        <div class="mb-3">
                            <label asp-for="AvatarUrl" class="form-label">URL Ảnh đại diện</label>
                            <input asp-for="AvatarUrl" class="form-control" placeholder="https://..." />
                        </div>
                        <button type="submit" class="btn btn-danger"><i class="fas fa-save me-2"></i>Lưu thay đổi</button>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
}
