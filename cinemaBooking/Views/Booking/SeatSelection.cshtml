@model cinemaBooking.Models.ViewModels.SeatSelectionViewModel
@{
    ViewData["Title"] = "Chọn ghế";
}

<div class="container mt-4">
    <h3 class="fw-bold mb-1"><i class="fas fa-chair me-2 text-danger"></i>Chọn ghế</h3>
    <p class="text-muted">@Model.MovieTitle · @Model.StartTime.ToString("HH:mm dd/MM/yyyy") · @Model.CinemaName · @Model.RoomName</p>

    <!-- Screen -->
    <div class="screen-container text-center my-3">
        <div class="screen-bar">MÀN HÌNH</div>
    </div>

    <!-- Seat Map -->
    <form asp-action="Create" method="post" id="bookingForm">
        @Html.AntiForgeryToken()
        <input type="hidden" name="ShowtimeId" value="@Model.ShowtimeId" />
        <input type="hidden" name="PaymentMethod" value="Mock" />

        <div class="seat-map mb-4">
            @foreach (var row in Model.SeatRows)
            {
                <div class="seat-row d-flex align-items-center gap-1 mb-1">
                    <span class="row-label fw-bold me-2">@row.RowLabel</span>
                    @foreach (var seat in row.Seats)
                    {
                        if (seat.IsBooked)
                        {
                            <div class="seat seat-booked" title="@seat.RowLabel@seat.SeatNumber - Đã đặt">
                                <i class="fas fa-times"></i>
                            </div>
                        }
                        else
                        {
                            <div class="seat seat-@seat.SeatType.ToLower() cursor-pointer"
                                 data-seat-id="@seat.Id"
                                 data-seat-label="@seat.RowLabel@seat.SeatNumber"
                                 data-seat-price="@seat.Price"
                                 title="@seat.RowLabel@seat.SeatNumber - @seat.SeatType - @seat.Price.ToString("N0")đ"
                                 onclick="toggleSeat(this)">
                                @seat.SeatNumber
                            </div>
                        }
                    }
                </div>
            }
        </div>

        <!-- Legend -->
        <div class="d-flex gap-3 mb-4 flex-wrap">
            <div class="d-flex align-items-center gap-2"><div class="seat seat-regular" style="width:28px;height:28px;font-size:12px;"></div> Regular</div>
            <div class="d-flex align-items-center gap-2"><div class="seat seat-vip" style="width:28px;height:28px;font-size:12px;"></div> VIP</div>
            <div class="d-flex align-items-center gap-2"><div class="seat seat-couple" style="width:28px;height:28px;font-size:12px;"></div> Couple</div>
            <div class="d-flex align-items-center gap-2"><div class="seat seat-booked" style="width:28px;height:28px;font-size:12px;"></div> Đã đặt</div>
            <div class="d-flex align-items-center gap-2"><div class="seat seat-selected" style="width:28px;height:28px;font-size:12px;"></div> Đã chọn</div>
        </div>

        <!-- Summary -->
        <div class="card sticky-bottom-card">
            <div class="card-body">
                <div class="row align-items-center">
                    <div class="col-md-8">
                        <p class="mb-1"><strong>Ghế đã chọn:</strong> <span id="selectedSeatsText">Chưa chọn ghế</span></p>
                        <p class="mb-0"><strong>Tổng tiền:</strong> <span id="totalPrice" class="text-danger fw-bold fs-5">0đ</span></p>
                        <div id="hiddenSeatInputs"></div>
                    </div>
                    <div class="col-md-4 text-end">
                        <button type="submit" id="btnConfirm" class="btn btn-danger btn-lg" disabled>
                            <i class="fas fa-ticket-alt me-2"></i>Tiếp tục
                        </button>
                    </div>
                </div>
            </div>
        </div>
    </form>
</div>

@section Scripts {
<script>
    const selectedSeats = {};

    function toggleSeat(el) {
        const seatId = el.dataset.seatId;
        const label = el.dataset.seatLabel;
        const price = parseFloat(el.dataset.seatPrice);

        if (selectedSeats[seatId]) {
            delete selectedSeats[seatId];
            el.classList.remove('seat-selected');
        } else {
            selectedSeats[seatId] = { label, price };
            el.classList.add('seat-selected');
        }
        updateSummary();
    }

    function updateSummary() {
        const keys = Object.keys(selectedSeats);
        const total = Object.values(selectedSeats).reduce((s, v) => s + v.price, 0);

        document.getElementById('selectedSeatsText').textContent =
            keys.length > 0 ? Object.values(selectedSeats).map(s => s.label).join(', ') : 'Chưa chọn ghế';
        document.getElementById('totalPrice').textContent =
            total.toLocaleString('vi-VN') + 'đ';

        const inputContainer = document.getElementById('hiddenSeatInputs');
        inputContainer.innerHTML = '';
        keys.forEach(id => {
            const input = document.createElement('input');
            input.type = 'hidden';
            input.name = 'SelectedSeatIds';
            input.value = id;
            inputContainer.appendChild(input);
        });

        document.getElementById('btnConfirm').disabled = keys.length === 0;
    }
</script>
}
